--> Process source files and prepare the final code.

local fs = require("@lune/fs")
local serde = require("@lune/serde")

local Polytoria_file_tools = require("../miscellaneous/file_tools")
local replace_JSON = require("../miscellaneous/replace_JSON")

local empty_array_object: {object} = replace_JSON.empty_array_any
local empty_array_string: {string} = replace_JSON.empty_array_any
type file_data = Polytoria_file_tools.file_data
type object = Polytoria_file_tools.object

type MetadataKind = fs.MetadataKind

type container = object | file_data

type build_state = {
	script_service: object,
}

type code_meta_data = {
	id: string,
}

type object_properties = {
	Tags: {string},
	[string]: any,
}

type object_properties_convenient = {
	Tags: {string}?,
	[string]: any,
}

type script_context = "client" | "server" | "none"

local extension_client = ".client.luau"
local extension_server = ".server.luau"
local extension_none = ".luau"
local path_source_relative = "./source"
local path_build_relative = "./build"
local path_build_prefix_pattern = "%./build/%./"
local path_require_generator = "./source/./require_generator.luau"

-- Preserve script line numbers.
local header = "--[[This file was generated by a build process.]]local require = require(ScriptService:FindChild(\"require_generator\"))(script)"

local extension_to_class_name: {[script_context]: string} = {
	client = "ClientScript",
	server = "ServerScript",
	none = "ModuleScript",
}

--[=[
	Written by DarkenedRing, edited by EliTheGingerCat.

	Version 4. Variant 1.
]=]
local function generate_UUId(): string
	-- Link IDs and object IDs are v4 UUIDs. I do not think math.random is up to security standards, but that doesn't matter here.
	-- In fact, I doubt it is even necessary for the ID to be a valid UUID, but let's do it anyway.
	-- https://www.rfc-editor.org/info/rfc9562

	-- Fill with random data.
	local bytes: {number} = table.create(16)
	for i = 1, 16 do
		bytes[i] = math.random(0, 255)
	end

	-- Set the version field (0b0100, which is 4).
	bytes[7] = bit32.bor(bit32.band(bytes[7], 0b00001111), 0b01000000)
	-- Set the variant field (0b10, which is 2).
	bytes[9] = bit32.bor(bit32.band(bytes[9], 0b00111111), 0b10000000)

	return string.format("%02x%02x%02x%02x-%02x%02x-%02x%02x-%02x%02x-%02x%02x%02x%02x%02x%02x", table.unpack(bytes))
end

--[=[
	Written by DarkenedRing, edited by EliTheGingerCat.
]=]
local function create_object(class_name: string, name: string, properties: object_properties_convenient?): object
	if properties == nil then
		properties = {
			Tags = {}, -- This empty array will be fixed later.
		}
	end
	assert(properties ~= nil, "language analysis")

	if properties.Tags == nil then
		properties.Tags = {} -- This empty array will be fixed later.
	end
	assert(properties.Tags ~= nil, "language analysis")

	-- ~ Investigate: For some reason, `Properties.Tags` is sometimes "{}".

	return {
		Children = {},
		ClassName = class_name,
		ID = generate_UUId(),
		IsLinkedChild = false,
		LinkedModel = replace_JSON.null,
		Name = name,
		Properties = properties,
	}
end

--[=[
	Written by DarkenedRing, edited by EliTheGingerCat.
]=]
local function get_children(container: container): {object}
	local container_object_maybe: object = container :: any
	if container_object_maybe.Children ~= nil then
		return container_object_maybe.Children
	else
		local container_file_data: file_data = container :: any
		return container_file_data.Objects
	end
end

local function find_by_name(parent: container, name: string): object?
	for _, child in get_children(parent) do
		if child.Name == name then
			return child
		end
	end

	return nil
end

--[=[
	Written by DarkenedRing, edited by EliTheGingerCat.
]=]
local function find_by_class(parent: container, class_name: string): object?
	for _, child in get_children(parent) do
		if child.ClassName == class_name then
			return child
		end
	end

	return nil
end

type end_configuration = {
	class_name: string,
	name: string,
	properties: object_properties_convenient?,
}

--[=[
	@return -- The link id found.
]=]
local function apply_configuration(object: object, end_configuration: end_configuration): string?
	object.ClassName = end_configuration.class_name
	object.Name = end_configuration.name

	local link_id_found = object.Properties.LinkedScript

	if end_configuration.properties then
		for property_name, property_value in end_configuration.properties do
			if property_name == "LinkedScript" then
				if link_id_found == nil then
					object.Properties.LinkedScript = property_value
				end
			end

			object.Properties[property_name] = property_value
		end
	end

	return link_id_found
end

--[=[
	@return -- The link id found.
]=]
local function ensure_path_exists(start: object, path: string, end_configuration: end_configuration): string?
	local current = start
	local components = string.split(path, "/")
	local components_size = #components
	for index = 1, components_size - 1 do
		local component = components[index]
		if component == "." then
			continue
		end

		local next_object = find_by_name(current, component)
		if next_object == nil then
			next_object = create_object("Folder", component)
			assert(next_object ~= nil, "language analysis")
			table.insert(current.Children, next_object)
		end
		assert(next_object ~= nil, "language analysis")

		current = next_object
	end

	local last_object = find_by_name(current, end_configuration.name)
	local link_id_found: string?
	if last_object == nil then
		last_object = create_object(end_configuration.class_name, end_configuration.name, end_configuration.properties)
		assert(last_object ~= nil, "language analysis")
		table.insert(current.Children, last_object)
	else
		link_id_found = apply_configuration(last_object, end_configuration)
	end
	assert(last_object ~= nil, "language analysis")

	return link_id_found
end

local function read_meta_file(path: string): code_meta_data
	local data_JSON = fs.readFile(path)
	local data = serde.decode("json", data_JSON)
	return data
end

local function write_meta_file(path: string, link_id: string): ()
	local data: code_meta_data = {
		id = link_id,
	}
	local data_string = serde.encode("json", data, true)
	local data_string_final = data_string .. "\n"
	fs.writeFile(path, data_string_final)
end

local function get_file_name(path: string): string?
	local _, index_last_slash = string.find(path, ".*/")
	if index_last_slash == nil then
		print(`Error: Path "{path}" has no slashes.`)
		return nil
	end

	local file_name = string.sub(path, index_last_slash + 1)
	return file_name
end

type script_details = {
	context: script_context,
	name: string,
}

--[=[
	Written by DarkenedRing, edited by EliTheGingerCat.
]=]
local function separate_script_context(file_name: string): script_details?
	if string.sub(file_name, -#extension_client, -1) == extension_client then
		local index_name_end = -#extension_client - 1
		local details = {
			context = "client" :: "client",
			name = string.sub(file_name, 1, index_name_end)
		}
		return details
	elseif string.sub(file_name, -#extension_server, -1) == extension_server then
		local index_name_end = -#extension_server - 1
		local details = {
			context = "server" :: "server",
			name = string.sub(file_name, 1, index_name_end)
		}
		return details
	elseif string.sub(file_name, -#extension_none, -1) == extension_none then
		local index_name_end = -#extension_none - 1
		local details = {
			context = "none" :: "none",
			name = string.sub(file_name, 1, index_name_end)
		}
		return details
	else
		print(`Unable to determine the script type of file "{file_name}".`)
		return nil
	end
end

local function process_file(state: build_state, path_from: string, path_to: string): ()
	local is_Luau = string.sub(path_from, -5, -1) == ".luau"
	local is_require_generator = path_from == path_require_generator

	if is_Luau == true then
		local link_id_meta_file: string
		local link_id_meta_existed: boolean
		local meta_of_path_to = path_to .. ".meta"
		if fs.metadata(meta_of_path_to).exists then
			local code_meta_data = read_meta_file(meta_of_path_to)
			link_id_meta_file = code_meta_data.id
			link_id_meta_existed = true
		else
			link_id_meta_file = generate_UUId()
			link_id_meta_existed = false
			write_meta_file(meta_of_path_to, link_id_meta_file)
		end

		local file_name = get_file_name(path_to)
		if file_name == nil then
			return
		end

		local script_details = separate_script_context(file_name)
		if script_details == nil then
			return
		end

		local class_name = extension_to_class_name[script_details.context]

		local script_configuration = {
			class_name = class_name,
			name = script_details.name,
			properties = {
				IsEnabled = false,
				LinkedScript = link_id_meta_file,
				Compatibility = false,
			},
		}

		local _, prefix_index_end = string.find(path_to, path_build_prefix_pattern)
		if prefix_index_end == nil then
			print(`Error: Build prefix was not found in path "{path_to}".`)
			return
		end

		local instance_path = string.sub(path_to, prefix_index_end + 1)

		local link_id_world_file = ensure_path_exists(state.script_service, instance_path, script_configuration)
		if link_id_world_file ~= nil and link_id_world_file ~= link_id_meta_file then
			if link_id_meta_existed == true then
				print(`Warning: The link id in the world file differs from the one in the metadata file. I will proceed anyway.\nScript path: \`{path_from}\`.\nWorld file: "{link_id_world_file}".\nMetadata file: "{link_id_meta_file}".`)
			end
			write_meta_file(meta_of_path_to, link_id_world_file)
		end

		local content_Luau_current = fs.readFile(path_from)
		local content_Luau_new: string
		if is_require_generator == true then
			content_Luau_new = content_Luau_current
		else
			content_Luau_new = header .. content_Luau_current
		end
		fs.writeFile(path_to, content_Luau_new)
	else
		-- Maybe other file formats will be added in the future.
		print(`Error: Unknown file type at path "{path_from}".`)
	end
end

-- This setup is very similar to `move_Git_files`. Maybe refactoring is possible.
local function process_all_files(build_state: build_state)
	local path_queue = {"."}
	local path_queue_index = 0

	while true do
		path_queue_index += 1
		local path_item = path_queue[path_queue_index]
		if path_item == nil then
			break
		end

		-- Relative to project root.
		local path_full_from = path_source_relative .. "/" .. path_item
		local path_full_to = path_build_relative .. "/" .. path_item
		local kind: MetadataKind? = fs.metadata(path_full_from).kind
		if kind == "file" then
			process_file(build_state, path_full_from, path_full_to)
		elseif kind == "dir" then
			fs.writeDir(path_full_to)
			for _, child in fs.readDir(path_full_from) do
				table.insert(path_queue, path_item .. "/" .. child)
			end
		else
			print(`Kind "{kind}" is not supported.`)
		end
	end
end

local function fix_empty_arrays(file_data: file_data): ()
	if #file_data.NonInstanceObjects == 0 then
		file_data.NonInstanceObjects = empty_array_string
	end

	local world = file_data.Objects[1]
	local object_queue = {world}
	local object_queue_index = 0
	local object_queue_size = #object_queue

	while true do
		object_queue_index += 1
		local object_current = object_queue[object_queue_index]
		if object_current == nil then
			break
		end

		if object_current.Properties.Tags ~= nil and #object_current.Properties.Tags == 0 then
			object_current.Properties.Tags = empty_array_string
		end

		if #object_current.Children == 0 then
			object_current.Children = empty_array_object
		else
			-- Using `object_children_size` is slightly confusing, but I think it could lead to a significant speed increase.
			local object_children_size = #object_current.Children
			table.move(object_current.Children, 1, object_children_size, object_queue_size + 1, object_queue)
			object_queue_size += object_children_size
		end

		-- Specific arrays are checked here. However, it is possible for other empty arrays to appear. Rather than process every single table in the root object, I decided to check below for any "{}". I might change this in the future. My main reason is that I think it will always be possible to be precise with which arrays are checked, and that is always faster. Another reason is to learn if new arrays enter the Polytoria datamodel- er, filemodel?
	end
end

-- The idea of creating a `build` function is copied from DarkenedRing.
local function build(path_source_absolute: string): ()
	-- ~ Todo: Use `path_source_absolute` more.

	local path_world = `{path_source_absolute}/main.poly`
	local file_data = Polytoria_file_tools.read_world_file(path_world)

	if file_data.FileType ~= 0 then
		print("Error: `./main.poly` is not a world file.")
		return
	end
	if #file_data.Objects ~= 1 then
		print("Error: At root, file does not contain exactly 1 object.")
		return
	end

	local world_object = file_data.Objects[1]
	if world_object.ClassName ~= "World" then
		print(`Error: Root object has class-name "{world_object.ClassName}" instead of "World".`)
		return
	end

	local script_service = find_by_class(world_object, "ScriptService")
	if script_service == nil then
		script_service = create_object("ScriptService", "ScriptService")
		assert(script_service ~= nil, "language analysis")
		table.insert(world_object.Children, script_service)
	end
	assert(script_service ~= nil, "language analysis")

	fs.writeDir(path_build_relative)

	local build_state: build_state = {
		script_service = script_service,
	}

	-- This is the main work.
	process_all_files(build_state)
	fix_empty_arrays(file_data)

	local JSON_data = serde.encode("json", file_data, true)
	local JSON_data_replaced = replace_JSON.replace(JSON_data)

	local index_empty_array = string.find(JSON_data_replaced, "{}")
	if index_empty_array ~= nil then
		print("Error: \"{}\" was found, which is likely an empty array that was not properly serialised. I will output to `./main_poly_error.json`.")
		fs.writeFile("./main_poly_error.json", JSON_data_replaced)
		return
	end

	local JSON_data_final = JSON_data_replaced .. "\n"
	Polytoria_file_tools.write_JSON_data(path_world, JSON_data_final)
end

-- ~ Todo: Allow setting path in command options.
build(".")
